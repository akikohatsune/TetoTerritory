# Discord
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
COMMAND_PREFIX=!
BOT_OWNER_USER_ID=
RPC_ENABLED=true
RPC_STATUS=online
RPC_ACTIVITY_TYPE=playing
RPC_ACTIVITY_NAME=with AI chats
RPC_ACTIVITY_URL=

# AI provider: gemini, groq, openai, openrouter, or chatgpt (alias of openai)
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
APPROVAL_GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_APPROVAL_MODEL=gemini-3-flash-preview

# Groq
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (ChatGPT models)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=openai/gpt-4o-mini

# Chat behavior
SYSTEM_PROMPT=You are Teto, a playful AI assistant on Discord. Reply in the same language as the user's latest message. Keep a light, fun tone while staying helpful and respectful.
SYSTEM_RULES_PATH=system_rules.md
PERSONA2_ENABLED=false
PERSONA2_NAME=persona2
LLM_PROVIDER_2=groq
SYSTEM_PROMPT_2=You are Persona2, a strict and concise AI assistant on Discord. Reply in the same language as the user's latest message.
SYSTEM_RULES_PATH_2=system_rule2.md
PERSONA2_KEYWORDS_PATH=persona2_keywords.md
# When PERSONA2_ENABLED=true, set provider-specific *_API_KEY_2 explicitly.
# If main and persona2 use the same provider, *_API_KEY_2 must be different from main key.
GEMINI_API_KEY_2=
GEMINI_MODEL_2=gemini-3-flash-preview
GROQ_API_KEY_2=
GROQ_MODEL_2=llama-3.3-70b-versatile
OPENAI_API_KEY_2=
OPENAI_MODEL_2=gpt-4o-mini
OPENROUTER_API_KEY_2=
OPENROUTER_MODEL_2=openai/gpt-4o-mini
CHAT_REPLAY_LOG_PATH=logger/chat_replay.jsonl

# Storage and limits
MEMORY_DB_PATH=data/chat_memory.db
CHAT_MEMORY_DB_PATH=data/chat_memory.db
BAN_DB_PATH=data/ban_control.db
CALLNAMES_DB_PATH=data/callnames.db
MEMORY_IDLE_TTL_SECONDS=300
IMAGE_MAX_BYTES=5242880
MAX_REPLY_CHARS=1800
TEMPERATURE=0.7
MAX_HISTORY=10
